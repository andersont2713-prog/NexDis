# Copiar a `.env.local` en esta carpeta (NexDis). No subir secretos al repo.

# --- MySQL (prioridad 1 en el API: por encima de Supabase y memoria) ---
# phpMyAdmin no es la BD: es la interfaz. La BD es MySQL/MariaDB (p. ej. XAMPP).
# Tras crear la base en phpMyAdmin, inicializa tablas: npm run db:init
#
# Opción A — URL única (Railway MySQL u otros suelen dar algo como mysql://...)
# MYSQL_URL=mysql://user:password@host:3306/nexdis
#
# Opción B — variables sueltas (típico XAMPP en local)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=nexdis
# Producción con SSL obligatorio: MYSQL_SSL=true
#
# --- Railway (MySQL plugin en el mismo proyecto) ---
# 1) Canvas: + New → Database → MySQL.
# 2) Servicio NexDis → Variables → "Reference variable" del servicio MySQL.
#    Referencia cada una tal cual (Railway ya usa MYSQL_URL o MYSQLHOST, etc.).
#    Este proyecto acepta MYSQLHOST / MYSQLUSER / … además de MYSQL_HOST / …
# 3) Primera vez: aplica el esquema. Opciones:
#    - TCP Proxy en el MySQL de Railway, copia host/puerto a .env.local y:
#      npm run db:init
#    - O ejecuta mysql/schema.sql con un cliente MySQL contra esa instancia.
# Doc: https://docs.railway.app/databases/mysql

# --- Gemini (opcional, si usas características IA) ---
GEMINI_API_KEY=

# --- Supabase (servidor Express / tsx server.ts) ---
# Settings → API: Project URL y service_role key (solo backend; no exponer en el navegador).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (frontend Vite — anon key es pública; protege con RLS en Supabase) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
