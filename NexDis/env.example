# Copiar a `.env.local` en esta carpeta (NexDis). No subir secretos al repo.

# --- Gemini (opcional, si usas características IA) ---
GEMINI_API_KEY=

# --- Supabase (servidor Express / tsx server.ts) ---
# Settings → API: Project URL y service_role key (solo backend; no exponer en el navegador).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (frontend Vite — anon key es pública; protege con RLS en Supabase) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
